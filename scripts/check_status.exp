#!/usr/bin/expect -f
set timeout 300

set host "146.103.111.109"
set user "root"
set password "W749a#j%37z8_138UBYA"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "password:"
send "$password\r"
expect "#"

send "cd /root/healthvault\r"
expect "#"

# Check running containers
send "docker-compose ps\r"
expect "#"

# Check CPU usage
send "top -b -n 1 | head -15\r"
expect "#"

send "exit\r"
expect eof
