#!/usr/bin/expect -f
set timeout 600

set host "146.103.111.109"
set user "root"
set password "W749a#j%37z8_138UBYA"
set local_tests_path "/Users/alexlyskovsky/HealthVault/tests"

# 1. SCP tests folder to remote host
spawn scp -r -o StrictHostKeyChecking=no $local_tests_path $user@$host:/root/healthvault/
expect "password:"
send "$password\r"
expect eof

# 2. Connect to remote to setup and run
spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "password:"
send "$password\r"
expect "#"

send "cd /root/healthvault\r"
expect "#"

# Copy tests into container
send "docker cp tests healthvault_bot:/app/tests\r"
expect "#"

# Install pytest and pytest-asyncio (needed for async tests)
send "docker exec healthvault_bot pip install pytest pytest-asyncio httpx\r"
expect "#"

# Run tests
send "docker exec healthvault_bot python -m pytest\r"
expect "#"

send "exit\r"
expect eof
