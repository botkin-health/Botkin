#!/usr/bin/expect -f
set timeout 60

set host "146.103.111.109"
set user "root"
set password "SERVER_PASSWORD_REDACTED"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "password:"
send "$password\r"
expect "#"

send "cd /root/healthvault\r"
expect "#"

# Check logs
send "docker logs healthvault_bot --tail 50\r"
expect "#"

send "exit\r"
expect eof
