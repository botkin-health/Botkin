# Botkin Environment Variables Example
# Copy this to .env and fill in your actual values

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=895655
# Секрет из setWebhook(secret_token=...) — проверяется на /telegram/webhook,
# защита от поддельных Update из docker-сети. openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32

# WHOOP OAuth — подпись state (защита от привязки чужого аккаунта).
# openssl rand -hex 32. При отсутствии fallback на APPLE_HEALTH_TOKEN.
WHOOP_STATE_SECRET=generate_with_openssl_rand_hex_32

# OpenAI API Key (распознавание еды, голоса)
OPENAI_API_KEY=sk-proj-your_key_here

# Google Gemini API (работает из России)
GEMINI_API_KEY=your_gemini_key_here

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=healthvault
DB_USER=healthvault
DB_PASSWORD=your_password_here

# Application Settings
LOG_LEVEL=INFO
CACHE_DIR=/app/data/cache
