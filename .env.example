# HealthVault Environment Variables Example
# Copy this to .env and fill in your actual values

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=895655

# OpenAI API Key (распознавание еды, голоса)
OPENAI_API_KEY=sk-proj-your_key_here

# Google Gemini API (работает из России)
GEMINI_API_KEY=AIzaSy_GCP_KEY_REDACTED

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=healthvault
DB_USER=healthvault
DB_PASSWORD=your_password_here

# Application Settings
LOG_LEVEL=INFO
CACHE_DIR=/app/data/cache
